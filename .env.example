# =============================================================================
# Finance AI Agent - Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All settings have sensible defaults except API keys (required).

# =============================================================================
# API Keys (REQUIRED)
# =============================================================================
GROQ_API_KEY=your_key_here          # Get from: https://console.groq.com/keys
EXA_API_KEY=your_key_here           # Get from: https://exa.ai/
ALPHAVANTAGE_API_KEY=your_key_here  # Get from: https://www.alphavantage.co/support/#api-key

# =============================================================================
# LLM Configuration
# =============================================================================
GROQ_MODEL=groq/llama-3.3-70b-versatile  # Recommended model for tool calling
LITELLM_LOG=ERROR                         # Reduce LiteLLM logging noise

# =============================================================================
# News Settings
# =============================================================================
NEWS_DAYS_BACK=7              # How many days back to search (1-30)
NEWS_LIMIT=4                  # Number of news articles to fetch (1-10)
NEWS_MAX_SUMMARY_CHARS=220    # Max chars per article summary (50-1000)
USE_INCLUDE_DOMAINS=true      # Use whitelist of trusted news domains

# =============================================================================
# Price Analysis Settings
# =============================================================================
PRICE_WINDOW_DAYS=120         # Days of price history for analysis (7-365)
PRICE_LAST_N=10               # Number of recent prices to show (1-30)

# =============================================================================
# Cache Settings
# =============================================================================
CACHE_TTL_HOURS=4             # Alpha Vantage cache TTL in hours (0.5-24)
EXA_CACHE_TTL_MINUTES=20      # Exa news cache TTL in minutes (5-60)

# =============================================================================
# Debug Settings
# =============================================================================
DEBUG=false                   # Set to true for full stack traces on errors