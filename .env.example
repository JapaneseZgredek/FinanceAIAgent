# =============================================================================
# Finance AI Agent - Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All settings have sensible defaults except API keys (required).

# =============================================================================
# API Keys (REQUIRED)
# =============================================================================
ALPHAVANTAGE_API_KEY=your_key_here  # Get from: https://www.alphavantage.co/support/#api-key

# =============================================================================
# LLM Configuration
# =============================================================================
CLAUDE_MODEL=claude-opus-4-6  # Model ID passed to the Claude API

# =============================================================================
# News Settings
# =============================================================================
NEWS_DAYS_BACK=7              # How many days back to search for news (1-30)

# =============================================================================
# Price Analysis Settings
# =============================================================================
PRICE_WINDOW_DAYS=120         # Days of price history used for analysis (7-365)
PRICE_LAST_N=10               # Number of recent daily closes shown in output (1-30)

# =============================================================================
# Cache Settings
# =============================================================================
CACHE_TTL_HOURS=4                     # Alpha Vantage price cache TTL in hours (0.5-24)
CLAUDE_NEWS_CACHE_TTL_MINUTES=30      # News cache TTL in minutes (5-120)
